# ------------------------------------------------------------
# Prediction helper with coefficient simulation
# Robust version for survreg objects
# ------------------------------------------------------------

predict_survreg_ci <- function(fit, times, arm_values = c("IV", "NEB"), n_sim = 2000) {
  
  beta_hat <- stats::coef(fit)
  
  # vcov(fit) may include additional parameters such as log(scale)
  vcov_full <- stats::vcov(fit)
  vcov_beta <- vcov_full[names(beta_hat), names(beta_hat), drop = FALSE]
  
  scale_hat <- fit$scale
  
  beta_sim <- MASS::mvrnorm(
    n = n_sim,
    mu = beta_hat,
    Sigma = vcov_beta
  )
  
  out <- list()
  
  for (arm in arm_values) {
    
    newdata <- data.frame(
      ARM = factor(arm, levels = c("IV", "NEB"))
    )
    
    # Safer model matrix construction
    X <- stats::model.matrix(
      stats::delete.response(stats::terms(fit)),
      newdata
    )
    
    # Ensure same columns as beta
    X <- X[, names(beta_hat), drop = FALSE]
    
    lp_hat <- as.numeric(X %*% beta_hat)
    
    lp_sim <- as.numeric(beta_sim %*% as.numeric(X))
    
    surv_hat <- 1 - survival::psurvreg(
      q = times,
      mean = lp_hat,
      scale = scale_hat,
      distribution = fit$dist
    )
    
    surv_sim <- sapply(lp_sim, function(lp_i) {
      1 - survival::psurvreg(
        q = times,
        mean = lp_i,
        scale = scale_hat,
        distribution = fit$dist
      )
    })
    
    surv_lcl <- apply(surv_sim, 1, stats::quantile, probs = 0.025, na.rm = TRUE)
    surv_ucl <- apply(surv_sim, 1, stats::quantile, probs = 0.975, na.rm = TRUE)
    
    out[[arm]] <- data.frame(
      Time_min = times,
      surv = surv_hat,
      lcl = surv_lcl,
      ucl = surv_ucl,
      ARM = arm
    )
  }
  
  dplyr::bind_rows(out) %>%
    dplyr::mutate(
      ARM = factor(ARM, levels = c("IV", "NEB"))
    )
}


times_pred <- seq(0.01, max(all_times), by = 0.1)

pred_lognormal_ci <- predict_survreg_ci(
  fit = fit_lognormal,
  times = times_pred,
  arm_values = c("IV", "NEB"),
  n_sim = 2000
)

