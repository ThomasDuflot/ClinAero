        else suppressWarnings(stats::chisq.test(tab, correct = FALSE)$p.value)
      } else NA_real_
    },

    .groups = "drop"
  ) %>%
  arrange(Time_min) %>%
  mutate(
    p_nrs   = fmt_p(p.adjust(p_nrs_raw, method = "holm")),
    p_relief = fmt_p(p.adjust(p_relief_raw, method = "holm"))
  ) %>%
  transmute(
    `Time (min)` = Time_min,
    `N` = N_overall, `N (IV)` = N_IV, `N (NEB)` = N_NEB,

    `Numeric Rating Scale` = NRS_Overall,
    `Numeric Rating Scale (IV)` = NRS_IV,
    `Numeric Rating Scale (NEB)` = NRS_NEB,
    `p (NRS, Holm)` = p_nrs,

    `NRS < 4` = Relief_Overall,
    `NRS < 4 (IV)` = Relief_IV,
    `NRS < 4 (NEB)` = Relief_NEB,
    `p (NRS<4, Holm)` = p_relief
  )

