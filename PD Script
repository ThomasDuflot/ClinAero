# 2) Split by ARM (same panel)
# --------------------------
summ_mean_sd_by_time <- function(df, group_vars) {
  df %>%
    filter(!is.na(EN), !is.na(Time_min)) %>%
    group_by(across(all_of(group_vars))) %>%
    summarise(
      n = sum(!is.na(EN)),
      mean = mean(EN, na.rm = TRUE),
      sd = sd(EN, na.rm = TRUE),
      .groups = "drop"
    )
}

