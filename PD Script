# --------------------------
# 1) Formatting helpers
# --------------------------
fmt3 <- function(x) {
  if (length(x) == 0) return("")
  ifelse(is.na(x), "", format(signif(x, 3), trim = TRUE, scientific = FALSE))
}

fmt_mean_sd <- function(x, N_ref) {
  n <- sum(!is.na(x))
  if (n == 0) return("")
  m <- mean(x, na.rm = TRUE)
  s <- sd(x, na.rm = TRUE)

  base <- paste0(fmt3(m), " ± ", fmt3(s))
  if (!missing(N_ref) && n < N_ref) paste0(base, " (n=", n, ")") else base
}

fmt_n_pct <- function(x01, N_ref) {
  n <- sum(!is.na(x01))
  if (n == 0) return("")
  n1 <- sum(x01 == 1, na.rm = TRUE)
  pct <- 100 * n1 / n

  base <- paste0(n1, " (", fmt3(pct), "%)")
  if (!missing(N_ref) && n < N_ref) paste0(base, " (n=", n, ")") else base
}

# Vectorized p formatter (FIX)
fmt_p <- function(p) {
  if (length(p) == 0) return("")
  out <- rep("", length(p))
  ok <- !is.na(p)
  out[ok & p < 0.001] <- "<0.001"
  out[ok & p >= 0.001] <- sprintf("%.3f", p[ok & p >= 0.001])
  out
}

# --------------------------
# 2) Normality rule (overall)
# --------------------------
normality_flag <- function(x) {
  x <- x[!is.na(x)]
  if (length(x) < 3) return(FALSE)
  skw <- tryCatch(moments::skewness(x), error = function(e) NA_real_)
  krt <- tryCatch(moments::kurtosis(x), error = function(e) NA_real_)
  isTRUE(!is.na(skw) && !is.na(krt) && abs(skw) < 1 && krt >= 2 && krt <= 5)
}

# numeric test with code: a=t-test, b=Wilcoxon
test_num_with_code <- function(x, g) {
  ok <- !is.na(x) & !is.na(g)
  x <- x[ok]
  g <- droplevels(as.factor(g[ok]))

  if (length(unique(g)) < 2) return(list(p = NA_real_, code = ""))

  # protect: need at least 2 obs per group for most tests
  n_by <- table(g)
  if (any(n_by < 2)) return(list(p = NA_real_, code = ""))

  # protect: constant x
  if (sd(x, na.rm = TRUE) == 0) return(list(p = NA_real_, code = ""))

  if (normality_flag(x)) {
    p <- tryCatch(stats::t.test(x ~ g)$p.value, error = function(e) NA_real_)
    list(p = p, code = "a")
  } else {
    # wilcox can fail on ties/constant within groups; catch it
    p <- tryCatch(stats::wilcox.test(x ~ g, exact = FALSE)$p.value, error = function(e) NA_real_)
    list(p = p, code = "b")
  }
}

# categorical test with code: c=Chi², d=Fisher
test_cat_with_code <- function(x, g) {
  ok <- !is.na(x) & !is.na(g)
  x <- x[ok]
  g <- droplevels(as.factor(g[ok]))

  if (length(unique(g)) < 2) return(list(p = NA_real_, code = ""))

  tab <- table(x, g)

  # If any expected count < 5 -> Fisher (more standard rule)
  chi <- tryCatch(suppressWarnings(stats::chisq.test(tab, correct = FALSE)),
                  error = function(e) NULL)

  if (is.null(chi)) {
    p <- tryCatch(stats::fisher.test(tab)$p.value, error = function(e) NA_real_)
    return(list(p = p, code = "d"))
  }

  if (any(chi$expected < 5)) {
    p <- tryCatch(stats::fisher.test(tab)$p.value, error = function(e) NA_real_)
    list(p = p, code = "d")
  } else {
    list(p = chi$p.value, code = "c")
  }
}

