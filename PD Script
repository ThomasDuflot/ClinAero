N_neb     <- nrow(neb)

# --------------------------
# 4) Row builder
# --------------------------
rows <- list()

add_row <- function(label, overall_val, iv_val, neb_val, p_obj = NULL) {
  rows[[length(rows) + 1]] <<- tibble(
    Variable = label,
    Overall  = overall_val,
    IV       = iv_val,
    NEB      = neb_val,
    p_num    = if (!is.null(p_obj)) p_obj$p else NA_real_,
    p_code   = if (!is.null(p_obj)) p_obj$code else ""
  )
}

