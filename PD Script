# 6) Flextable (NEJM-ish) + superscripts
# --------------------------
ft <- flextable(final_table %>% select(Variable, Overall, IV, NEB, p_value_txt, p_code)) %>%
  set_header_labels(
    Overall = paste0("Overall (N=", N_overall, ")"),
    IV      = paste0("IV (N=", N_iv, ")"),
    NEB     = paste0("NEB (N=", N_neb, ")"),
    p_value_txt = "p-value"
  ) %>%
  theme_booktabs() %>%
  font(fontname = "Times New Roman", part = "all") %>%
  fontsize(size = 10, part = "all") %>%
  padding(padding = 2, part = "all") %>%
  bold(part = "header") %>%
  align(align = "left", j = 1, part = "all") %>%
  align(align = "center", j = 2:5, part = "all")

# add superscript letter to p-values
ft <- compose(
  ft, j = "p_value_txt",
  value = as_paragraph(
    as_chunk(p_value_txt),
    as_sup(as_chunk(p_code))
  )
)

# drop helper column used for superscripts
ft <- delete_columns(ft, j = "p_code") %>%
  autofit()

# footer legend
ft <- add_footer_lines(
  ft,
  values = "Tests: a t-test (overall skew/kurtosis normal); b Wilcoxon rank-sum; c Chi-square; d Fisher's exact. (n=...) shown only when missing data."
)

