library(dplyr)
library(survival)
library(survminer)
library(ggplot2)
library(ggsci)

# ------------------------------------------------------------
# 1) Theme
# ------------------------------------------------------------

my_theme <- theme_minimal(base_size = 16) +
  theme(
    axis.title = element_text(size = 18, color = "black"),
    axis.text = element_text(size = 16, color = "black"),
    axis.line = element_line(linewidth = 1.5),
    legend.title = element_text(size = 18, color = "black"),
    legend.text = element_text(size = 16, color = "black")
  )

# ------------------------------------------------------------
# 2) Patient-level survival dataset
# ------------------------------------------------------------

surv_data <- data_pd2 %>%
  filter(!is.na(ID), !is.na(ARM), !is.na(Time_min)) %>%
  arrange(ID, Time_min) %>%
  group_by(ID) %>%
  summarise(
    ARM = first(ARM),
    
    # First timepoint where NRS < 4
    time_to_relief = if (any(!is.na(EN) & EN < 4)) {
      min(Time_min[!is.na(EN) & EN < 4])
    } else {
      max(Time_min[!is.na(EN)])
    },
    
    # Event indicator
    # 1 = relief reached at least once
    # 0 = never reached relief, censored at last observed time
    event_relief = as.integer(any(!is.na(EN) & EN < 4)),
    
    .groups = "drop"
  ) %>%
  mutate(
    ARM = factor(ARM, levels = c("IV", "NEB"))
  )

# Check number of events / censored patients
table(surv_data$ARM, surv_data$event_relief)

# ------------------------------------------------------------
# 3) Kaplan-Meier fit
# ------------------------------------------------------------

fit_km <- survfit(
  Surv(time_to_relief, event_relief) ~ ARM,
  data = surv_data
)

# ------------------------------------------------------------
# 4) Exploratory Cox model
# ------------------------------------------------------------

cox_model <- coxph(
  Surv(time_to_relief, event_relief) ~ ARM,
  data = surv_data,
  ties = "efron"
)

summary(cox_model)

# ------------------------------------------------------------
# 5) Extract HR, 95% CI and p-value
# IV is the reference group
# ------------------------------------------------------------

cox_res <- summary(cox_model)

hr      <- cox_res$conf.int["ARMNEB", "exp(coef)"]
ci_low  <- cox_res$conf.int["ARMNEB", "lower .95"]
ci_high <- cox_res$conf.int["ARMNEB", "upper .95"]
p_val   <- cox_res$coefficients["ARMNEB", "Pr(>|z|)"]

p_txt <- ifelse(
  p_val < 0.001,
  "<0.001",
  sprintf("%.3f", p_val)
)

cox_text <- paste0(
  "NEB vs IV: HR = ",
  sprintf("%.2f", hr),
  " [95% CI: ",
  sprintf("%.2f", ci_low),
  "–",
  sprintf("%.2f", ci_high),
  "], p = ",
  p_txt
)

