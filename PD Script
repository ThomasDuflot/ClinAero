# =========================================
# TABLE 1 (manual) -> flextable -> Word
# - Overall / IV / NEB with N in headers
# - All numeric vars: mean ± sd
# - Categorical: n (%)
# - Add "(n=...)" ONLY when missing exists in that column
# - p-values with superscripts: a t-test, b Wilcoxon, c Chi², d Fisher
# - Subrows for Cotreatment and Side Effects
# - 3 significant digits for numbers (110, 23.4, 3.29 style)
# =========================================

library(dplyr)
