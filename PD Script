    )
  )


time_labels <- gsub("^T", "", levels(data_pd2$T_PROTO))

# --------------------------
# Summary function
# --------------------------
summ_mean_sem <- function(df, group_vars) {
  df %>%
    filter(!is.na(EN), !is.na(T_PROTO)) %>%
    group_by(across(all_of(group_vars))) %>%
    summarise(
      n = sum(!is.na(EN)),
      mean = mean(EN, na.rm = TRUE),
      sd = sd(EN, na.rm = TRUE),
      sem = sd / sqrt(n),
      .groups = "drop"
    )
}

# --------------------------
# 1) Overall
# --------------------------
sum_overall <- summ_mean_sem(data_pd2, c("T_PROTO"))

p1 <- ggplot(sum_overall,
             aes(x = T_PROTO, y = mean, group = 1)) +
  geom_ribbon(aes(ymin = mean - sd, ymax = mean + sd),
              alpha = 0.2) +
  geom_line(linewidth = 1.2) +
  geom_point(size = 2) +
  scale_x_discrete(labels = time_labels) +
  labs(
    x = "Time (min)",
    y = "Numeric Rating Scale"
  ) +
  my_theme

