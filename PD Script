# --------------------------
# 1) Formatting helpers
# --------------------------
fmt3 <- function(x) {
  if (length(x) == 0) return("")
  ifelse(is.na(x), "", format(signif(x, 3), trim = TRUE, scientific = FALSE))
}

fmt_mean_sd <- function(x, N_ref) {
  n <- sum(!is.na(x))
  if (n == 0) return("")
  m <- mean(x, na.rm = TRUE)
  s <- sd(x, na.rm = TRUE)

  base <- paste0(fmt3(m), " ± ", fmt3(s))
  if (!missing(N_ref) && n < N_ref) paste0(base, " (n=", n, ")") else base
}

fmt_n_pct <- function(x01, N_ref) {
  n <- sum(!is.na(x01))
  if (n == 0) return("")
  n1 <- sum(x01 == 1, na.rm = TRUE)
  pct <- 100 * n1 / n

  base <- paste0(n1, " (", fmt3(pct), "%)")
  if (!missing(N_ref) && n < N_ref) paste0(base, " (n=", n, ")") else base
}

fmt_p <- function(p) {
  if (is.na(p) || length(p) == 0) return("")
  if (p < 0.001) return("<0.001")
  sprintf("%.3f", p)
}

# --------------------------
# 2) Normality rule (overall)
# --------------------------
normality_flag <- function(x) {
  x <- x[!is.na(x)]
  if (length(x) < 3) return(FALSE)
  skw <- tryCatch(moments::skewness(x), error = function(e) NA_real_)
  krt <- tryCatch(moments::kurtosis(x), error = function(e) NA_real_)
  isTRUE(!is.na(skw) && !is.na(krt) && abs(skw) < 1 && krt >= 2 && krt <= 5)
}

# numeric test with code: a=t-test, b=Wilcoxon
test_num_with_code <- function(x, g) {
  ok <- !is.na(x) & !is.na(g)
  x <- x[ok]; g <- droplevels(g[ok])
  if (length(unique(g)) < 2) return(list(p = NA_real_, code = ""))

  if (normality_flag(x)) {
    list(p = stats::t.test(x ~ g)$p.value, code = "a")
  } else {
    list(p = stats::wilcox.test(x ~ g)$p.value, code = "b")
  }
}

# categorical test with code: c=Chi², d=Fisher
test_cat_with_code <- function(x, g) {
  ok <- !is.na(x) & !is.na(g)
  x <- x[ok]; g <- droplevels(g[ok])
  if (length(unique(g)) < 2) return(list(p = NA_real_, code = ""))

  tab <- table(x, g)
  if (any(tab < 5)) {
    list(p = stats::fisher.test(tab)$p.value, code = "d")
  } else {
    list(p = stats::chisq.test(tab)$p.value, code = "c")
  }
}

