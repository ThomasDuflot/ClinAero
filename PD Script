tab_time <- dp %>%
  filter(!is.na(EN), !is.na(ARM), !is.na(Time_min)) %>%
  group_by(Time_min) %>%
  summarise(
    N_overall = sum(!is.na(EN)),
    N_IV      = sum(!is.na(EN[ARM == "IV"])),
    N_NEB     = sum(!is.na(EN[ARM == "NEB"])),

    Overall = fmt_mean_sd(EN),
    IV      = fmt_mean_sd(EN[ARM == "IV"]),
    NEB     = fmt_mean_sd(EN[ARM == "NEB"]),

    p_raw   = {
      if (N_IV >= 1 && N_NEB >= 1) {
        tryCatch(
          stats::wilcox.test(EN ~ ARM, exact = FALSE)$p.value,
          error = function(e) NA_real_
        )
      } else NA_real_
    },
    .groups = "drop"
  ) %>%
  arrange(Time_min) %>%
  mutate(
    p_adj = p.adjust(p_raw, method = "holm"),
    `p-value (Holm)` = fmt_p(p_adj)
  ) %>%
  select(
    `Time (min)` = Time_min,
    `N` = N_overall,
    `N (IV)` = N_IV,
    `N (NEB)` = N_NEB,
    Overall, IV, NEB,
    `p-value (Holm)`
  )

